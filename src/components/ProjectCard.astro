---
import type { Project } from '../content/projects'

interface Props {
  project: Project
}

const { project } = Astro.props
---

<article
  class="bg-surface border border-border rounded-lg p-5 flex flex-col gap-3 h-full"
>
  <!-- Header row -->
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-semibold text-primary text-sm">{project.title}</h3>
    <div class="flex flex-wrap gap-1 justify-end flex-shrink-0">
      {project.stack.slice(0, 2).map(tag => (
        <span class="font-mono text-[10px] text-muted bg-page px-1.5 py-0.5 rounded">
          {tag}
        </span>
      ))}
    </div>
  </div>

  <!-- Description -->
  <p class="text-secondary text-xs leading-relaxed flex-1">{project.description}</p>

  <!-- CTA -->
  <p class="text-muted text-[11px]">
    {project.caseStudy ? '→ Case study' : '→ View project'}
  </p>
</article>
