---
import ScrollReveal from './ScrollReveal.astro'
---

<footer id="contact" class="py-8 px-6 border-t border-border">
  <div class="max-w-4xl mx-auto">
    <ScrollReveal>
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2">
        <p class="text-xs text-muted">Open to opportunities · 2026</p>
        <a
          href="mailto:asidbatte@gmail.com"
          aria-label="Send email to asidbatte@gmail.com"
          data-cursor-label="Mail"
          class="text-xs text-muted hover:opacity-60 transition-opacity"
        >
          asidbatte@gmail.com
        </a>
      </div>
    </ScrollReveal>
  </div>
</footer>
