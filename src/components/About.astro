---
import ScrollReveal from './ScrollReveal.astro'
---

<section id="about" class="py-24 px-6 border-t border-border">
  <div class="max-w-4xl mx-auto">
    <ScrollReveal>
      <p class="font-mono text-[10px] tracking-[2px] text-muted uppercase mb-10">About</p>
    </ScrollReveal>

    <ScrollReveal delay={100}>
      <div class="flex flex-col sm:flex-row items-start gap-6">
        <!-- Avatar -->
        <div class="shrink-0">
          <img
            src="https://avatars.githubusercontent.com/aryansidbatte"
            alt="Aryan Sidbatte"
            width="80"
            height="80"
            loading="lazy"
            class="rounded-full border border-border w-20 h-20 object-cover"
          />
        </div>

        <!-- Content -->
        <div>
          <p class="text-sm font-semibold text-primary mb-3">Aryan Sidbatte</p>
          <ul>
            <li class="text-xs text-secondary leading-loose">· CS: Computer Game Design B.S., UC Santa Cruz</li>
            <li class="text-xs text-secondary leading-loose">· Ships web apps and game systems</li>
            <li class="text-xs text-secondary leading-loose">· Looking for SWE, fullstack, and game dev work</li>
          </ul>
          <div class="flex gap-4 mt-4">
            <a
              href="https://github.com/aryansidbatte"
              target="_blank"
              rel="noopener noreferrer"
              data-cursor-label="Visit"
              data-magnetic
              class="text-[11px] text-muted underline-offset-2 hover:underline transition-all"
            >
              GitHub ↗
            </a>
            <a
              href="https://linkedin.com/in/aryan-sidbatte"
              target="_blank"
              rel="noopener noreferrer"
              data-cursor-label="Visit"
              data-magnetic
              class="text-[11px] text-muted underline-offset-2 hover:underline transition-all"
            >
              LinkedIn ↗
            </a>
            <a
              href="/resume.pdf"
              target="_blank"
              rel="noopener noreferrer"
              data-cursor-label="Open"
              data-magnetic
              class="text-[11px] text-muted underline-offset-2 hover:underline transition-all"
            >
              Resume ↗
            </a>
          </div>
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>
