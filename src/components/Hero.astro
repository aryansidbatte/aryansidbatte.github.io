---
// Static — no props
---

<section class="min-h-svh flex flex-col items-center justify-center px-6 relative pt-14">
  <canvas
    id="sand-drift"
    aria-hidden="true"
    style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;"
  ></canvas>
  <div class="max-w-4xl w-full flex flex-col items-center gap-8 md:flex-row md:items-center md:gap-12" style="position:relative;z-index:1;">
    <div class="flex-1 text-center md:text-left">
    <!-- Eyebrow: delay 0.5s -->
    <p
      class="hero-animate font-mono text-[10px] tracking-[2px] text-muted uppercase mb-4"
      style="--anim-delay: 0.5s; --anim-duration: 0.65s; --slide-from: 14px;"
    >
      Software Engineer
    </p>

    <!-- Name: delay 0.72s -->
    <h1
      class="hero-animate text-4xl md:text-5xl font-bold text-primary tracking-tight leading-[1.1] mb-4"
      style="--anim-delay: 0.72s; --anim-duration: 0.75s; --slide-from: 20px;"
    >
      Aryan Sidbatte
    </h1>

    <!-- Subtitle: delay 0.97s -->
    <p
      class="hero-animate text-sm text-muted mb-8"
      style="--anim-delay: 0.97s; --anim-duration: 0.65s; --slide-from: 14px;"
    >
      CS + Game Design · UC Santa Cruz · San Jose, CA
    </p>

    <!-- CTAs: stagger 1.25 / 1.4 / 1.55s -->
    <div class="flex flex-wrap gap-3">
      <a
        href="https://github.com/aryansidbatte"
        target="_blank"
        rel="noopener noreferrer"
        data-cursor-label="Visit"
        data-magnetic
        class="hero-animate px-4 py-2 text-sm text-secondary border border-border rounded-md bg-surface hover:opacity-60 transition-opacity"
        style="--anim-delay: 1.25s; --anim-duration: 0.5s; --slide-from: 12px;"
      >
        GitHub ↗
      </a>
      <a
        href="https://www.linkedin.com/in/aryan-sidbatte/"
        target="_blank"
        rel="noopener noreferrer"
        data-cursor-label="Visit"
        data-magnetic
        class="hero-animate px-4 py-2 text-sm text-secondary border border-border rounded-md bg-surface hover:opacity-60 transition-opacity"
        style="--anim-delay: 1.4s; --anim-duration: 0.5s; --slide-from: 12px;"
      >
        LinkedIn ↗
      </a>
      <a
        href="https://drive.google.com/file/d/1ea81Wfv5BwG8RPc-GOBcotjVJqLf3a72/view?usp=sharing"
        target="_blank"
        rel="noopener noreferrer"
        data-cursor-label="Open"
        data-magnetic
        class="hero-animate px-4 py-2 text-sm bg-primary text-page rounded-md hover:opacity-60 transition-opacity"
        style="--anim-delay: 1.55s; --anim-duration: 0.5s; --slide-from: 12px;"
      >
        Resume ↗
      </a>
    </div>
    </div>

    <!-- Avatar: wrapper is the click target + layout anchor (never rotates).
         Inner img receives the rotateY transform so hit area stays full-size. -->
    <div
      id="hero-avatar-wrapper"
      class="hero-animate flex-shrink-0 w-[130px] h-[130px] md:w-[210px] md:h-[210px] rounded-full order-first md:order-last"
      style="--anim-delay: 0.72s; --anim-duration: 0.75s; --slide-from: 20px; cursor: pointer; user-select: none; -webkit-user-select: none;"
    >
      <img
        id="hero-avatar"
        src="/images/avatar.jpeg"
        alt="Aryan Sidbatte"
        draggable="false"
        class="w-full h-full rounded-full object-cover object-top border-2 border-border"
        style="-webkit-user-drag: none;"
      />
    </div>
  </div>

  <!-- Scroll indicator: fadeIn at 1.9s then bounces -->
  <a href="#work" data-cursor-scale class="hero-bounce absolute bottom-8 left-1/2 -translate-x-1/2 text-muted text-sm hover:text-primary transition-colors" aria-label="Scroll to work">
    ↓
  </a>
</section>


<script>
import {
  PART_RADIUS,
  scaleParticles,
  applyPartingForce,
  applyOrbitForce,
  applyExplosionForce,
  updateVelocity,
  wrapEdges,
  type Particle,
} from '../lib/sand-drift'

const section = document.querySelector('section') as HTMLElement
const canvas = document.getElementById('sand-drift') as HTMLCanvasElement
const ctx = canvas.getContext('2d')!

let W: number, H: number
let particles: Particle[] = []
let prevW: number | undefined
let prevH: number | undefined
let t = 0
let rafId: number

const cursor = { x: -9999, y: -9999, active: false }

// Easter egg state
const ENERGY_PER_CLICK = 0.4
const ENERGY_DECAY = 0.98
const ORBIT_THRESHOLD = 0.65
const SPIN_DEG_PER_ENERGY = 12
const COAST_DEG_PER_FRAME = 2
const EXPLOSION_FRAMES = 20
const ORBIT_STRENGTH = 0.5      // lower = closer orbit, higher = wider
const EXPLOSION_STRENGTH = 8.0

let energy = 0
let inOrbit = false
let exploding = false
let explodeFrames = 0
let avatarCx = -9999
let avatarCy = -9999
let spinAngle = 0               // current Y-rotation in degrees, JS-driven

// Wrapper: layout anchor + click target (never transforms — hit area stays full-size).
// Inner img: receives rotateY so the visual spins without shrinking the clickable area.
const avatarWrapper = document.getElementById('hero-avatar-wrapper') as HTMLDivElement
const avatarEl = document.getElementById('hero-avatar') as HTMLImageElement

// After the entrance animation finishes, remove hero-animate so its forwards fill
// no longer overrides style.transform (CSS animations beat inline styles).
avatarWrapper.addEventListener('animationend', (e) => {
  if (e.animationName === 'slideUp') {
    avatarWrapper.classList.remove('hero-animate')
    avatarWrapper.style.opacity = '1'
  }
}, { once: true })

function updateAvatarCenter() {
  const avatarRect = avatarWrapper.getBoundingClientRect()
  const sectionRect = section.getBoundingClientRect()
  avatarCx = avatarRect.left + avatarRect.width / 2 - sectionRect.left
  avatarCy = avatarRect.top + avatarRect.height / 2 - sectionRect.top
}

function initCanvas() {
  const dpr = window.devicePixelRatio || 1
  canvas.width = W * dpr
  canvas.height = H * dpr
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0)
}

function draw() {
  // Energy decay
  energy *= ENERGY_DECAY

  // JS-driven spin: increment spinAngle by energy each frame.
  // As energy decays, increments shrink → natural visual deceleration.
  // CSS animations override style.transform, so hero-animate is removed on
  // animationend above; after that, style.transform is ours to set freely.
  const degPerFrame = energy * SPIN_DEG_PER_ENERGY
  const isCoasting = degPerFrame < COAST_DEG_PER_FRAME && spinAngle > 0.5
  const speed = isCoasting ? COAST_DEG_PER_FRAME : degPerFrame

  if (speed > 0 || spinAngle > 0.5) {
    const prevAngle = spinAngle
    spinAngle = (spinAngle + speed) % 360
    // While coasting, stop as soon as we wrap past 0 (clean stop at full revolution)
    if (isCoasting && prevAngle > spinAngle && (prevAngle - spinAngle) > 180) {
      spinAngle = 0
      avatarEl.style.transform = ''
    } else {
      avatarEl.style.transform = `perspective(400px) rotateY(${spinAngle.toFixed(1)}deg)`
    }
  } else if (spinAngle <= 0.5 && spinAngle > 0) {
    spinAngle = 0
    avatarEl.style.transform = ''
  }

  // State transitions
  if (!inOrbit && energy > ORBIT_THRESHOLD) inOrbit = true
  if (inOrbit && energy <= ORBIT_THRESHOLD && !exploding) {
    inOrbit = false
    exploding = true
    explodeFrames = EXPLOSION_FRAMES
  }
  if (exploding) {
    explodeFrames--
    if (explodeFrames <= 0) exploding = false
  }

  // 1. Trail fade
  ctx.fillStyle = 'rgba(250,250,249,0.35)'
  ctx.fillRect(0, 0, W, H)

  // 2. Update and draw each particle
  for (const p of particles) {
    const dxC = p.x - cursor.x
    const dyC = p.y - cursor.y

    if (exploding) {
      applyExplosionForce(p, avatarCx, avatarCy, EXPLOSION_STRENGTH)
    } else if (inOrbit) {
      applyOrbitForce(p, avatarCx, avatarCy, ORBIT_STRENGTH)
      // Per-particle radial oscillation thickens the orbit band
      const dxA = p.x - avatarCx
      const dyA = p.y - avatarCy
      const d = Math.sqrt(dxA * dxA + dyA * dyA) || 1
      const spread = Math.sin(t * 0.02 + p.baseVx * 40 + p.size * 20) * ORBIT_STRENGTH * 0.8
      p.vx += (dxA / d) * spread
      p.vy += (dyA / d) * spread
    } else {
      applyPartingForce(p, cursor.x, cursor.y, cursor.active)
    }
    updateVelocity(p, t)
    p.x += p.vx
    p.y += p.vy
    wrapEdges(p, W, H)

    ctx.beginPath()
    ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2)
    ctx.fillStyle = cursor.active && (dxC * dxC + dyC * dyC) < PART_RADIUS * PART_RADIUS
      ? 'rgba(28,25,23,0.08)'
      : 'rgba(28,25,23,0.22)'
    ctx.fill()
  }

  t++
  rafId = requestAnimationFrame(draw)
}

// Single init path via ResizeObserver (fires once immediately on observe)
const ro = new ResizeObserver(() => {
  cancelAnimationFrame(rafId)
  W = section.offsetWidth
  H = section.offsetHeight
  if (!W || !H) return
  initCanvas()
  particles = scaleParticles(particles, prevW, prevH, W, H)
  prevW = W
  prevH = H
  updateAvatarCenter()
  rafId = requestAnimationFrame(draw)
})
ro.observe(section)

window.addEventListener('scroll', updateAvatarCenter, { passive: true })

avatarWrapper.addEventListener('click', () => {
  energy += ENERGY_PER_CLICK
  // If energy rebounds above threshold during explosion, cancel explosion and re-enter orbit
  if (exploding && energy > ORBIT_THRESHOLD) {
    exploding = false
    explodeFrames = 0
    inOrbit = true
  }
})

// Mouse tracking
section.addEventListener('mousemove', e => {
  const r = section.getBoundingClientRect()
  const x = e.clientX - r.left
  const y = e.clientY - r.top
  cursor.x = x
  cursor.y = y
  cursor.active = x >= 0 && x <= W && y >= 0 && y <= H
})

section.addEventListener('mouseleave', () => {
  cursor.active = false
  cursor.x = -9999
  cursor.y = -9999
})

</script>
